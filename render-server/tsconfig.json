{
    "compilerOptions": {
        "target": "ES2020",
        "module": "CommonJS",
        "lib": [
            "ES2020",
            "DOM"
        ],
        "jsx": "react",
        "outDir": "dist",
        "rootDir": ".",
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "strict": false,
        "skipLibCheck": true,
        "moduleResolution": "node"
    },
    "include": [
        "src/**/*",
        "compositions/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}