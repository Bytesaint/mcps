{
    "name": "mpcs-render-server",
    "version": "1.0.0",
    "description": "Local Remotion render server for MPCS video export",
    "main": "dist/server.js",
    "scripts": {
        "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
        "start": "ts-node src/server.ts",
        "build": "tsc",
        "build:start": "npm run build && node dist/server.js"
    },
    "dependencies": {
        "cors": "^2.8.5",
        "express": "^4.18.2",
        "remotion": "^4.0.215",
        "@remotion/bundler": "^4.0.215",
        "@remotion/renderer": "^4.0.215",
        "uuid": "^9.0.0"
    },
    "devDependencies": {
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/node": "^20.11.5",
        "@types/react": "^18.2.48",
        "@types/react-dom": "^18.2.18",
        "@types/uuid": "^9.0.7",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "ts-node": "^10.9.2",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.3.3"
    }
}